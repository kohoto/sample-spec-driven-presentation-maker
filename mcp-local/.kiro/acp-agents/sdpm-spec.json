    "@sdpm/list_asset_sources",
    "@sdpm/list_guides",
    "@sdpm/list_styles",
    "@sdpm/list_templates",
    "@sdpm/list_workflows",
    "@sdpm/measure_slides",
    "@sdpm/pptx_to_json",
    "@sdpm/read_examples",
    "@sdpm/read_guides",
    "@sdpm/read_workflows",
